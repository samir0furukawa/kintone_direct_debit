{
  "name": "kintone-billing-plugin",
  "version": "2.0.0",
  "description": "One-click setup Kintone billing automation plugin with auto-app creation",
  "author": "Your Company",
  "license": "MIT",
  "homepage": "https://github.com/samir0furukawa/kintone_direct_debit",
  "repository": {
    "type": "git",
    "url": "https://github.com/samir0furukawa/kintone_direct_debit.git"
  },
  "keywords": [
    "kintone",
    "plugin",
    "billing",
    "automation",
    "bank-transfer"
  ],
  "main": "dist/kintone-billing-plugin.zip",
  "scripts": {
    "dev": "webpack --mode development --watch",
    "build": "node build/scripts/prebuild.js && webpack --mode production && node build/scripts/postbuild.js",
    "package": "node build/package.js",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "validate": "node build/scripts/validate.js",
    "release": "npm run lint && npm run test && npm run build && npm run package",
    "sign": "node build/scripts/sign.js"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "babel-loader": "^9.1.3",
    "eslint": "^8.44.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "jest": "^29.6.0",
    "prettier": "^2.8.8",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3",
    "file-loader": "^6.2.0",
    "archiver": "^5.3.1",
    "chalk": "^4.1.2",
    "dotenv": "^16.3.1"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}