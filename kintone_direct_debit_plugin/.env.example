# Build environment
NODE_ENV=production

# Plugin configuration
PLUGIN_NAME=kintone-billing-plugin
PLUGIN_VERSION=2.0.0

# Plugin signing (optional)
PLUGIN_PRIVATE_KEY=your_private_key_here

# GitHub configuration
GITHUB_TOKEN=your_github_token
GITHUB_REPO=samir0furukawa/kintone_direct_debit

# Release configuration
VERSION=2.0.0
RELEASE_NOTES=Release notes here

# Analytics (optional)
SENTRY_DSN=

# Logging
LOG_LEVEL=info
DEBUG=false

# Build options
MINIFY=true
SOURCE_MAPS=false

# API configuration
API_TIMEOUT=30000
API_RETRIES=3